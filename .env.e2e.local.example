# ============================================================================
# .env.e2e.local  —  LOCAL E2E TEST CREDENTIALS  (copy this file to
# `.env.e2e.local` and fill in the values; the real file is git-ignored)
# ============================================================================
#
# WHY THIS FILE EXISTS
#   Your `.env.local` points at the PRODUCTION Supabase project. Running the
#   Playwright E2E suite (or `seed:test`) against production would create/delete
#   real data and WIPE the schema. This file lets the tests target a DEDICATED
#   TEST Supabase project instead — the same project CI uses.
#
#   `playwright.config.ts` loads this file FIRST, so any value set here overrides
#   `.env.local` for the test runner AND the dev server it spawns. It is never
#   used by `npm run dev` / production.
#
# HOW TO USE
#   1. Copy:            cp .env.e2e.local.example .env.e2e.local   (or copy in Explorer)
#   2. Fill the values below from your TEST Supabase project + Stripe test mode.
#      (Same values you put in the GitHub Actions repository secrets.)
#   3. Seed the test DB once:   npm run seed:test:e2e
#   4. Run the suite:           npm run test:e2e
#
# ── Supabase: your DEDICATED TEST project (NOT production) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
# Management API token (Supabase dashboard → Account → Access Tokens).
# Required by seed:test:e2e to reset the schema on the test project.
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# ── Stripe (TEST MODE keys — pk_test_… / sk_test_…) ─────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (optional; a test/throwaway Resend key or leave unset) ────────────
RESEND_API_KEY=

# ── Rate limiting: leave Upstash UNSET so the limiter uses the in-memory
#    fallback (resets per dev-server process) and won't cause flaky 429s. ─────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Test users (must match what seed:test:e2e creates) ──────────────────────
TEST_EMAIL=e2e-admin@example.com
TEST_PASSWORD=change-me
TEST_USER_EMAIL=e2e-customer@said-klima.de
TEST_USER_PASSWORD=change-me

# ── App / cron ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3100
CRON_SECRET=any-value-for-tests
