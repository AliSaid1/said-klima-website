# ─────────────────────────────────────────────────────────────────────────────
# Said Kälte- & Klimatechnik — Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# NEXT_PUBLIC_* variables are exposed to the browser — never put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + keys from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Service-role key — SERVER ONLY (webhooks, cron, admin scripts). Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Personal access token used by scripts/apply-migrations.mjs (npm run migrate)
SUPABASE_ACCESS_TOKEN="your-supabase-access-token"

# ── Stripe ──────────────────────────────────────────────────────────────────
# From: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret from: Stripe Dashboard → Developers → Webhooks
# (endpoint: https://YOUR-DOMAIN/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
# Optional in local dev — if unset, rate limiting is disabled gracefully.
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used for Stripe redirects, email links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron protection ─────────────────────────────────────────────────────────
# Shared secret; Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="a-long-random-string"

# ── Direct Postgres connection (optional; used by database/db.js) ─────────────
DATABASE_URL="postgres://user:password@host:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# E2E test credentials (Playwright) — only needed when running `npm test`.
# ─────────────────────────────────────────────────────────────────────────────
BASE_URL="http://localhost:3000"
TEST_EMAIL="admin@example.com"
TEST_PASSWORD="your-admin-password"
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="testPassword123"
